# ── Servidor ───────────────────────────────────────────────
PORT=4000
# Origem do frontend (CORS). Em dev: http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# ── Base de dados ──────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/innov

# ── Auth ───────────────────────────────────────────────────
# Google OAuth Client ID (Web). Mesmo valor no client (VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Segredo p/ assinar os JWT de sessão emitidos pelo backend. Gerar aleatório.
JWT_SECRET=troca-isto-por-um-segredo-aleatorio-longo
JWT_EXPIRES_IN=12h

# Email do 1º administrador (seed). Tem de ser uma conta Google real p/ login.
SEED_ADMIN_EMAIL=admin@empresa.pt

# ── Google Drive (fotos) ───────────────────────────────────
# Service Account JSON (caminho do ficheiro) com acesso à pasta de destino.
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
# ID da pasta raiz no Drive onde as fotos são guardadas (partilhada com a SA).
DRIVE_ROOT_FOLDER_ID=

# ── Notificações ao backoffice ─────────────────────────────
# Opcional: reutiliza o bot Telegram do maganalysis, ou deixa vazio (só in-app).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BACKOFFICE_CHAT_ID=
